   </define>
   <define name="mei_att.volta.vis.attributes">
      <ref name="mei_att.color.attributes"/>
      <ref name="mei_att.typography.attributes"/>
      <ref name="mei_att.visualOffset.to.attributes"/>
      <ref name="mei_att.visualOffset.vo.attributes"/>
      <ref name="mei_att.xy.attributes"/>
   </define>
   <define name="mei_model.draftsLike">
      <choice>
         <ref name="bw_drafts"/>
      </choice>
   </define>
   <define name="bw_drafts">
      <element name="drafts" ns="https://beethovens-werkstatt.de/ns/meiAdditions">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Provides a container for drafts.</a:documentation>
         <oneOrMore>
            <ref name="mei_model.draftLike"/>
         </oneOrMore>
         <ref name="mei_att.common.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_model.draftLike">
      <choice>
         <ref name="bw_draft"/>
      </choice>
   </define>
   <define name="bw_draft">
      <element name="draft" ns="https://beethovens-werkstatt.de/ns/meiAdditions">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A version of the musical content that is unfinished – a sketch, draft or similar.</a:documentation>
         <ref name="mei_model.pbLike"/>
         <oneOrMore>
            <ref name="mei_model.bwSystemLike"/>
         </oneOrMore>
         <zeroOrMore>
            <ref name="mei_del"/>
         </zeroOrMore>
         <ref name="mei_att.common.attributes"/>
         <ref name="mei_att.trans.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_model.bwSystemLike">
      <choice>
         <ref name="bw_system"/>
      </choice>
   </define>
   <define name="bw_system">
      <element name="system" ns="https://beethovens-werkstatt.de/ns/meiAdditions">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A system of one or more staff lines used for (a part of) a musical sketch.</a:documentation>
         <ref name="mei_model.scoreDefLike"/>
         <ref name="mei_model.sectionLike"/>
         <ref name="mei_att.common.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_word">
      <element name="word">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A single word, for which hyphenation may or may not be possible.</a:documentation>
         <text/>
         <ref name="mei_att.id.attributes"/>
         <ref name="mei_att.facsimile.attributes"/>
         <ref name="mei_att.staffIdent.attributes"/>
         <ref name="mei_att.xy.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_model.wordLike">
      <choice>
         <ref name="mei_word"/>
      </choice>
   </define>
   <define name="mei_att.rotation.attributes">
      <ref name="mei_att.rotation.attribute.rotate"/>
   </define>
   <define name="mei_att.rotation.attribute.rotate">
      <optional>
         <attribute name="rotate">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Describes rotation applied to the parent element. A positive value rotates in a counter-clockwise fashion, while negative values produce clockwise rotation.</a:documentation>
            <ref name="mei_data.ROTATION"/>
         </attribute>
      </optional>
   </define>
   <start>
      <choice>
         <ref name="mei_mei"/>
      </choice>
   </start>
   <sch:ns xmlns:rng="http://relaxng.org/ns/structure/1.0"
           xmlns:sch="http://purl.oclc.org/dsdl/schematron"
           xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"
           xmlns="http://www.tei-c.org/ns/1.0"
           prefix="mei"
           uri="http://www.music-encoding.org/ns/mei"/>
   <sch:ns xmlns:rng="http://relaxng.org/ns/structure/1.0"
           xmlns:sch="http://purl.oclc.org/dsdl/schematron"
           xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"
           xmlns="http://www.tei-c.org/ns/1.0"
           prefix="xlink"
           uri="http://www.w3.org/1999/xlink"/>
   <sch:ns xmlns:rng="http://relaxng.org/ns/structure/1.0"
           xmlns:sch="http://purl.oclc.org/dsdl/schematron"
           xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"
           xmlns="http://www.tei-c.org/ns/1.0"
           prefix="svg"
           uri="http://www.w3.org/2000/svg"/>
   <sch:ns xmlns:rng="http://relaxng.org/ns/structure/1.0"
           xmlns:sch="http://purl.oclc.org/dsdl/schematron"
           xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"
           xmlns="http://www.tei-c.org/ns/1.0"
           prefix="tei"
           uri="http://www.tei-c.org/ns/1.0"/>
   <sch:ns xmlns:rng="http://relaxng.org/ns/structure/1.0"
           xmlns:sch="http://purl.oclc.org/dsdl/schematron"
           xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"
           xmlns="http://www.tei-c.org/ns/1.0"
           prefix="bw"
           uri="https://beethovens-werkstatt.de/ns/meiAdditions"/>
</grammar>
