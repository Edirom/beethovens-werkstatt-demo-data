         <ref name="mei_persName"/>
      </choice>
   </define>
   <define name="mei_model.nameLike.agent_alternation">
      <choice>
         <ref name="mei_corpName"/>
         <ref name="mei_persName"/>
      </choice>
   </define>
   <define name="mei_model.nameLike.agent_sequence">
      <ref name="mei_corpName"/>
      <ref name="mei_persName"/>
   </define>
   <define name="mei_model.nameLike.agent_sequenceOptional">
