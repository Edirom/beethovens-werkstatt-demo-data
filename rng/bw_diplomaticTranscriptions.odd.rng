      <optional>
         <attribute name="num.place">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(number placement) States where the number will be placed in relation to the notational feature.</a:documentation>
            <ref name="mei_data.STAFFREL.basic"/>
         </attribute>
      </optional>
   </define>
   <define name="mei_att.numberPlacement.attribute.num.visible">
      <optional>
         <attribute name="num.visible">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Determines if the number is visible.</a:documentation>
